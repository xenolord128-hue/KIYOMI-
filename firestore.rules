rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions

    // Verify if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Verify if the signed-in user is a verified administrator
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'lord79915@gmail.com' ||
        request.auth.token.email == 'admin@kiyomi.com'
      );
    }

    // Verify if document IDs are structurally valid and safe from resource exhaustion attacks
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Default catch-all deny rule for complete system safety
    match /{document=**} {
      allow read, write: if false;
    }

    // Test connection documents for initial load health check
    match /test/{docId} {
      allow read: if true;
    }

    // --- Users Profile Collection Validation ---
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && request.auth.uid == userId && isValidUser(request.resource.data);
    }

    function isValidUser(u) {
      return u.uid == request.auth.uid 
        && u.email is string 
        && (u.displayName == null || u.displayName is string)
        && (u.photoURL == null || u.photoURL is string)
        && u.updatedAt is string;
    }

    // --- Products Collection Validation ---
    match /products/{productId} {
      allow get, list: if true;
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidId(productId) && isValidProduct(request.resource.data) 
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'id', 'title', 'category', 'price', 'rating', 'assets', 'variants', 'outOfStock', 'description', 'reviews', 'stock'
        ]);
      allow delete: if isAdmin();
    }

    function isValidProduct(p) {
      return p.id is number 
        && p.title is string && p.title.size() <= 200
        && p.category is string && p.category.size() <= 100
        && p.price is number && p.price >= 0
        && p.rating is number && p.rating >= 0 && p.rating <= 5
        && p.assets is list && p.assets.size() <= 10
        && p.variants is list && p.variants.size() <= 10
        && p.outOfStock is list && p.outOfStock.size() <= 10
        && p.description is string && p.description.size() <= 2000
        && p.reviews is list
        && (p.stock == null || (p.stock is number && p.stock >= 0));
    }

    // --- Orders Collection Validation ---
    match /orders/{orderId} {
      allow get: if true; // Allows clients to track specific lookup codes
      allow list: if isAdmin(); // Only admins can list all receipt indexes
      allow create: if isValidId(orderId) && isValidOrder(request.resource.data) 
        && request.resource.data.status == 'Received'; // Force Received invariant
      allow update: if isAdmin() && isValidId(orderId) && isValidOrder(request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
      allow delete: if isAdmin();
    }

    function isValidOrder(o) {
      return o.id is string && o.id.size() <= 100
        && o.fullName is string && o.fullName.size() <= 200
        && o.phone is string && o.phone.size() <= 30
        && o.address is string && o.address.size() <= 500
        && o.paymentMethod is string && o.paymentMethod.size() <= 100
        && o.items is list && o.items.size() <= 50
        && o.totalPrice is number && o.totalPrice >= 0
        && o.status is string && o.status in ['Received', 'Processing', 'Shipped', 'Out for Delivery', 'Completed']
        && o.createdAt is string;
    }

    // --- Settings Documents Verification ---
    match /settings/{settingsId} {
      allow get: if true;
      allow list: if isAdmin();
      allow write: if isAdmin() && isValidSettings(settingsId, request.resource.data);
    }

    function isValidSettings(id, data) {
      return id == 'announcements' 
        ? (data.message is string && data.message.size() <= 1000 && data.active is bool)
        : (id == 'adConfig' 
          ? (data.scriptBlock is string && data.scriptBlock.size() <= 50000 && data.enabled is bool)
          : false);
    }
  }
}
